{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "vercel dev (full: API + static)",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["vercel", "dev", "--listen", "3000"],
      "port": 3000
    },
    {
      "name": "static only (python http.server)",
      "runtimeExecutable": "python3",
      "runtimeArgs": ["-m", "http.server", "8000"],
      "port": 8000
    }
  ]
}
